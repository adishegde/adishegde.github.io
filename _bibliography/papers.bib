@inproceedings{AHL+21,
author = {Utkarsh Agrawal and Aditya Hegde and Rajesh Langoju and Prasad Sudhakar and Bhushan D. Patil and Sundar R. K. and Yasuhiro Imai and Risa Shigemasa and Omi Yasuo and Bipul Das},
title = {{Enhancing Z-resolution in CT volumes with deep residual learning}},
volume = {11596},
booktitle = {Medical Imaging 2021: Image Processing},
editor = {Ivana Išgum and Bennett A. Landman},
organization = {International Society for Optics and Photonics},
publisher = {SPIE},
pages = {603 -- 610},
tldr = {CT systems with large detector size suffer from lower z-resolution leading to pixelated images and inability to detect small structures thus adversely impacting the diagnosis and screening. In this work, we propose a supervised deep learning method for z-resolution enhancement such that (a) the effective SSP of resulting image is reduced, (b) quantitative values of tissue (CT numbers) and tissue-contrast are preserved; (c) there is very limited noise enhancement and (d) there is an improved tissue interface in bone/soft tissue.},
year = {2021},
doi = {https://doi.org/10.1117/12.2581273},
abbr = {SPIE},
selected = {false},
leadauth = {1}
}

